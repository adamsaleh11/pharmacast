# PharmaCast frontend environment
# These NEXT_PUBLIC_* values are exposed to the browser by Next.js.
# Do not put Supabase service-role keys or database passwords here.

# Supabase hosted project URL for the backend-configured project.
NEXT_PUBLIC_SUPABASE_URL=https://ebrxagoygjtnpzlnxtmr.supabase.co

# Supabase anon/publishable key from Project Settings > API.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Spring Boot API base URL.
NEXT_PUBLIC_API_URL=http://localhost:8080
